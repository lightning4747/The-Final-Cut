}
# TMDB API Key (Required for movie data)
TMDB_API_KEY=your_tmdb_api_key_here
# Supabase Configuration (Required for favorites/watchlist)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Appwrite Configuration (Required for trending movies/search counts)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_appwrite_project_id_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_appwrite_database_id_here
NEXT_PUBLIC_APPWRITE_COLLECTION_ID=your_appwrite_collection_id_here
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1